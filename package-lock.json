/* Social sign-in verification.
   PRODUCTION: verify the provider's ID token against its JWKS / tokeninfo endpoint
   and return the verified { email, name }. Wire real client IDs from config.
   DEV (ALLOW_SIMULATED_SOCIAL=true): trust the posted email so the
   "Continue with Google/Outlook/Yahoo/Apple" buttons work end-to-end locally. */
const config = require('../config');

const SUPPORTED = ['google', 'microsoft', 'outlook', 'yahoo', 'apple'];

async function verifyProvider({ provider, email, name, idToken }) {
  provider = String(provider || '').toLowerCase();
  if (!SUPPORTED.includes(provider)) { const e = new Error('Unsupported provider.'); e.status = 400; e.expose = true; throw e; }

  // --- Real verification goes here ---
  // if (provider === 'google') { verify idToken with Google, set email/name from claims }
  // if (provider === 'microsoft' || provider === 'outlook') { verify with Microsoft identity platform }
  // if (provider === 'apple') { verify with Apple public keys }

  if (idToken && false /* set true once real verification is implemented */) {
    // return { email: claims.email, name: claims.name, provider };
  }

  if (config.allowSimulatedSocial) {
    if (!email) { const e = new Error('A provider email is required.'); e.status = 400; e.expose = true; throw e; }
    return { email: String(email).toLowerCase(), name: name || email.split('@')[0], provider };
  }

  const e = new Error('Social sign-in is not configured on the server.');
  e.status = 501; e.expose = true; throw e;
}

module.exports = { verifyProvider, SUPPORTED };
